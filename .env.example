PORT=3000
CACHE_DB_PATH=./cache.sqlite
DISPLAY_CURRENCY=USD

# App Store Connect API key details
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_ID=ABC123DEFG
ASC_VENDOR_NUMBER=12345678
ASC_REQUEST_TIMEOUT_MS=30000
# Optional: pin report version (usually leave empty and let API choose latest)
# ASC_SALES_REPORT_VERSION=1_1

# Provide one of these:
ASC_PRIVATE_KEY_PATH=AuthKey_ABC123DEFG.p8
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
